{
    "files.associations": {
        "capability.h": "c",
        "random": "c",
        "role_manager.h": "c",
        "strings.h": "c",
        "string.h": "c",
        "stat.h": "c",
        "limits.h": "c",
        "xml_options.h": "c",
        "rar_env.h": "c",
        "errno.h": "c",
        "stdlib.h": "c",
        "syslog.h": "c",
        "types.h": "c",
        "array": "c",
        "string_view": "c",
        "initializer_list": "c",
        "xml_manager.h": "c",
        "cstring": "c",
        "string": "c",
        "sstream": "c",
        "command.h": "c",
        "unistd.h": "c",
        "stdint.h": "c",
        "criterion.h": "c",
        "typeinfo": "c"
    },
    "rust-analyzer.linkedProjects": [
        //"sudoers-reader/Cargo.toml",
        "Cargo.toml",
        //"./capable/Cargo.toml"
    ],
    "c-cpp-flylint.clang.includePaths": [
        "${workspaceFolder}/src"
    ],
    "terminal.integrated.env.linux": {
        "PROFILE" : "debug",
        "RUST_BACKTRACE" : "1",
    },
    "rust-analyzer.checkOnSave": true,
    "rust-analyzer.cargo.features": "all",
    "rust-analyzer.check.command": "clippy",
    "rust-analyzer.check.extraArgs": [
        "--",
        "-W", "clippy::pedantic",
        "-W", "clippy::nursery",
        "-A", "clippy::similar_names",
        "-A", "clippy::should_implement_trait",
        "-D", "warnings"
    ],
    // Optional: Enable all experimental features for stricter type checking/linting
    "rust-analyzer.diagnostics.experimental.enable": true

}